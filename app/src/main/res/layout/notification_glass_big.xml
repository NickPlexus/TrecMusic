<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/notif_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_notification_glass"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/notif_art"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_notification_art"
            android:clipToOutline="true"
            android:scaleType="centerCrop"
            android:src="@drawable/notification_art_placeholder" />

        <LinearLayout
            android:id="@+id/notif_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <TextView
                android:id="@+id/notif_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#FFFFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/notif_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/notif_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/notif_prev"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_notification_button"
            android:clickable="true"
            android:focusable="true"
            android:padding="7dp"
            android:src="@drawable/ic_notif_prev" />

        <ImageView
            android:id="@+id/notif_play"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_notification_button_primary"
            android:clickable="true"
            android:focusable="true"
            android:padding="9dp"
            android:src="@drawable/ic_notif_play" />

        <ImageView
            android:id="@+id/notif_next"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_notification_button"
            android:clickable="true"
            android:focusable="true"
            android:padding="7dp"
            android:src="@drawable/ic_notif_next" />
    </LinearLayout>
</LinearLayout>
